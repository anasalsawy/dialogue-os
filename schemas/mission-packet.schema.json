{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dialogue-os.example/schemas/mission-packet.schema.json",
  "title": "Dialogue OS Mission Packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mission_id",
    "objective",
    "accountable_owner",
    "priority",
    "domain",
    "constraints",
    "required_evidence",
    "allowed_tools",
    "side_effect_classes",
    "risk_level",
    "retry_policy",
    "escalation_triggers",
    "completion_criteria",
    "expected_final_format",
    "created_at"
  ],
  "properties": {
    "mission_id": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "accountable_owner": {"type": "string", "minLength": 1},
    "priority": {"enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]},
    "domain": {"type": "string", "minLength": 1},
    "constraints": {"type": "array", "items": {"type": "string"}},
    "required_evidence": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "allowed_tools": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "side_effect_classes": {
      "type": "array",
      "items": {"enum": ["READ_ONLY", "REVERSIBLE_INTERNAL", "REVERSIBLE_EXTERNAL", "IRREVERSIBLE_EXTERNAL", "FINANCIAL", "LEGAL_OR_IDENTITY", "COMMUNICATION", "PRIVILEGE_CHANGE"]},
      "uniqueItems": true
    },
    "risk_level": {"enum": ["LOW", "MODERATE", "HIGH", "CRITICAL"]},
    "retry_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_attempts_before_review", "backoff", "require_changed_hypothesis", "reconcile_unknown_side_effects"],
      "properties": {
        "max_attempts_before_review": {"type": "integer", "minimum": 1},
        "backoff": {"enum": ["NONE", "FIXED", "EXPONENTIAL", "ADAPTIVE"]},
        "require_changed_hypothesis": {"type": "boolean"},
        "reconcile_unknown_side_effects": {"type": "boolean"},
        "expires_at": {"type": ["string", "null"], "format": "date-time"}
      }
    },
    "escalation_triggers": {"type": "array", "items": {"type": "string"}},
    "completion_criteria": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "expected_final_format": {"enum": ["MARKDOWN", "JSON", "TABLE", "FILE", "ACTION_WITH_RECEIPT"]},
    "watcher_required": {"type": "boolean", "default": false},
    "created_at": {"type": "string", "format": "date-time"}
  }
}
