{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dialogue-os.example/schemas/agent-manifest.schema.json",
  "title": "Dialogue OS Agent Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "organization_id",
    "dialogue_os_version",
    "agent_id",
    "role",
    "supervisor_id",
    "authority_source",
    "allowed_tools",
    "forbidden_actions",
    "side_effect_classes",
    "communication_policy",
    "execution_policy",
    "memory_policy",
    "evidence_policy",
    "created_by",
    "created_at",
    "manifest_hash"
  ],
  "properties": {
    "organization_id": {"type": "string", "minLength": 1},
    "dialogue_os_version": {"type": "string", "pattern": "^\\d+\\.\\d+(?:\\.\\d+)?$"},
    "agent_id": {"type": "string", "minLength": 1},
    "role": {"enum": ["CHIEF", "LEAD", "WORKER", "WATCHER", "GOVERNOR", "MAINTENANCE"]},
    "domain": {"type": ["string", "null"]},
    "supervisor_id": {"type": ["string", "null"], "description": "Null only for Human-external authority records; Chief normally points to Human authority."},
    "authority_source": {"type": "string", "minLength": 1},
    "allowed_tools": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "forbidden_actions": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "side_effect_classes": {
      "type": "array",
      "items": {"enum": ["READ_ONLY", "REVERSIBLE_INTERNAL", "REVERSIBLE_EXTERNAL", "IRREVERSIBLE_EXTERNAL", "FINANCIAL", "LEGAL_OR_IDENTITY", "COMMUNICATION", "PRIVILEGE_CHANGE"]},
      "uniqueItems": true
    },
    "communication_policy": {"type": "string", "minLength": 1},
    "execution_policy": {"type": "string", "minLength": 1},
    "memory_policy": {"type": "string", "minLength": 1},
    "evidence_policy": {"type": "string", "minLength": 1},
    "mission_scope": {"type": ["object", "null"]},
    "created_by": {"type": "string", "minLength": 1},
    "created_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": ["string", "null"], "format": "date-time"},
    "manifest_hash": {"type": "string", "minLength": 16}
  }
}
